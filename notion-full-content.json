        },
        {
          "type": "bulleted_list_item",
          "text": "Campagna 1 — Keyword ad Alta Intenzione: €30/gg, Phrase match",
          "blockId": "30b2208f-6c7a-8108-8429-c82e1fd28b0e"
        },
        {
          "type": "bulleted_list_item",
          "text": "Campagna 2 — Difesa Brand: €10/gg, Exact match (\"362gradi\")",
          "blockId": "30b2208f-6c7a-81d0-b1bc-ca16c213150d"
